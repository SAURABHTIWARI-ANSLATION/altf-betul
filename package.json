{
  "name": "altftool",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "altftoolweb",
    "altftoolwebadmin",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:web && npm run build:admin",
    "build:web": "npm --prefix altftoolweb run build",
    "build:admin": "npm --prefix altftoolwebadmin run build",
    "bundle:audit": "node scripts/check-bundle-budgets.mjs",
    "dev:web": "npm --prefix altftoolweb run dev -- -p 3002",
    "dev:admin": "npm --prefix altftoolwebadmin run dev -- -p 3001",
    "start:web": "npm --prefix altftoolweb run start -- -p 3002",
    "start:admin": "npm --prefix altftoolwebadmin run start -- -p 3001",
    "lint:web": "npm --prefix altftoolweb run lint -- --quiet",
    "lint:web:budget": "node scripts/check-web-lint-budget.mjs",
    "audit": "npm run audit:web && npm run audit:admin",
    "audit:web": "npm --prefix altftoolweb audit --audit-level=moderate",
    "audit:admin": "npm --prefix altftoolwebadmin audit --audit-level=moderate",
    "routes:check": "node scripts/check-routes.mjs",
    "env:readiness": "node scripts/check-env-readiness.mjs",
    "env:readiness:strict": "ALTFT_ENV_STRICT=true node scripts/check-env-readiness.mjs --strict",
    "health:manifest": "node scripts/generate-admin-health-manifest.mjs",
    "health:manifest:check": "npm run health:manifest && git diff --exit-code -- altftoolwebadmin/src/data/healthManifest.json",
    "deploy:readiness": "node scripts/check-vercel-deploy-readiness.mjs",
    "firebase:check": "node scripts/check-firebase-contracts.mjs",
    "firebase:live-check": "node scripts/check-firebase-live-data.mjs",
    "firebase:admin-write-check": "npm --prefix altftoolwebadmin run firebase:admin-write-check",
    "firebase:admin-write-check:dry-run": "npm --prefix altftoolwebadmin run firebase:admin-write-check:dry-run",
    "firebase:emulator:preflight": "node scripts/check-firebase-emulator-prereqs.mjs",
    "firebase:admin-write-check:emulator": "npm run firebase:emulator:preflight && npx --yes firebase-tools@15.17.0 emulators:exec --only firestore --project altftool-bca36 \"npm --prefix altftoolwebadmin run firebase:admin-write-check\"",
    "media:check": "node scripts/check-public-media-budgets.mjs",
    "monitor:production": "node scripts/check-production-monitoring.mjs",
    "seo:blog-check": "node --no-warnings scripts/check-blog-seo-readiness.mjs",
    "seo:blog-live-check": "node --no-warnings scripts/check-blog-seo-readiness.mjs --live",
    "tools:check": "node --no-warnings scripts/check-tool-registry.mjs",
    "test:firebase-rules": "npm --prefix altftoolwebadmin run test:firebase-rules",
    "test:firebase-rules:emulator": "npm run firebase:emulator:preflight && npx --yes firebase-tools@15.17.0 emulators:exec --only firestore,storage --project altftool-bca36 \"npm run test:firebase-rules\"",
    "test:admin-crud": "npm --prefix altftoolwebadmin run test:admin-crud",
    "test:admin-crud:emulator": "npm run firebase:emulator:preflight && npx --yes firebase-tools@15.17.0 emulators:exec --only firestore --project altftool-bca36 \"npm run test:admin-crud\"",
    "test:admin-web-sync": "npm --prefix altftoolwebadmin run test:admin-web-sync",
    "test:admin-web-sync:emulator": "npm run firebase:emulator:preflight && npx --yes firebase-tools@15.17.0 emulators:exec --only firestore --project altftool-bca36 \"npm run test:admin-web-sync\"",
    "test:firebase-admin-write-check": "node --test tests/firebase-admin-write-check.test.mjs",
    "test:firebase-live-data-report": "node --test tests/firebase-live-data-report.test.mjs",
    "test:smoke": "playwright test tests/smoke.spec.mjs",
    "test:tools:functional": "ALTFT_SKIP_ADMIN_SERVER=true playwright test tests/tool-functional.spec.mjs",
    "test:tools:priority": "ALTFT_SKIP_ADMIN_SERVER=true playwright test tests/tool-priority.spec.mjs",
    "test:tools:all": "playwright test tests/tool-all-routes.spec.mjs",
    "test:routes": "ALTFT_PLAYWRIGHT_WEB_SERVER=production ALTFT_PLAYWRIGHT_ADMIN_SERVER=dev playwright test tests/route-audit.spec.mjs",
    "test:routes:dev": "playwright test tests/route-audit.spec.mjs",
    "test:admin-api": "playwright test tests/admin-api.spec.mjs",
    "test:firebase-public-pages": "playwright test tests/firebase-public-pages.spec.mjs",
    "test:mobile-ux": "ALTFT_SKIP_ADMIN_SERVER=true playwright test tests/mobile-ux.spec.mjs",
    "test:visual": "NEXT_PUBLIC_USE_MOCK=true playwright test tests/visual.spec.mjs",
    "test:visual:update": "NEXT_PUBLIC_USE_MOCK=true playwright test tests/visual.spec.mjs --update-snapshots",
    "test:security": "playwright test tests/security.spec.mjs",
    "test:lighthouse": "ALTFT_PLAYWRIGHT_WEB_SERVER=production ALTFT_PLAYWRIGHT_ADMIN_SERVER=dev playwright test tests/lighthouse.spec.mjs",
    "test:lighthouse:dev": "playwright test tests/lighthouse.spec.mjs",
    "validate": "npm run lint:web && npm run lint:web:budget && npm run routes:check && npm run tools:check && npm run seo:blog-check && npm run health:manifest:check && npm run env:readiness && npm run firebase:check && npm run media:check && npm run audit && npm run build && npm run bundle:audit && npm run test:smoke",
    "validate:full": "npm run validate && npm run test:routes && npm run test:tools:functional && npm run test:tools:priority && npm run test:mobile-ux && npm run test:admin-api && npm run test:firebase-admin-write-check && npm run test:firebase-live-data-report",
    "validate:release": "npm run validate:full && npm run firebase:live-check && npm run seo:blog-live-check && npm run test:firebase-public-pages && npm run test:security && npm run test:visual && npm run test:lighthouse"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.2.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4"
  },
  "overrides": {
    "postcss": "^8.5.14",
    "next": {
      "postcss": "^8.5.14"
    }
  },
  "dependencies": {
    "motion-dom": "^12.40.0"
  }
}
