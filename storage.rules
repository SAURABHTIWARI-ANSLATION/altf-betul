rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function adminDoc() {
      return /databases/(default)/documents/admins/$(request.auth.uid);
    }

    function isActiveAdmin() {
      return signedIn() &&
        firestore.exists(adminDoc()) &&
        firestore.get(adminDoc()).data.isActive == true;
    }

    function isSafeUpload(maxBytes) {
      return request.resource != null &&
        request.resource.size > 0 &&
        request.resource.size <= maxBytes &&
        (request.resource.contentType.matches("image/.*") ||
          request.resource.contentType.matches("video/.*") ||
          request.resource.contentType == "application/pdf");
    }

    match /admin-avatars/{uid} {
      allow read: if true;
      allow create, update: if isActiveAdmin() &&
        request.auth.uid == uid &&
        isSafeUpload(5 * 1024 * 1024);
      allow delete: if isActiveAdmin() && request.auth.uid == uid;
    }

    match /{path=**} {
      allow read: if true;
      allow create, update: if isActiveAdmin() && isSafeUpload(100 * 1024 * 1024);
      allow delete: if isActiveAdmin();
    }
  }
}
